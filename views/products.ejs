<!DOCTYPE html>
<html lang="en">

<%-include("./partials/head.ejs")%>

    <body>

        <%-include("./partials/header.ejs")%>

        <div class="header">
            <div class="title-header">
                <h2>MIRÁ UN ADELANTO<br><span>&nbsp;&nbsp;&nbsp;&nbsp; DE LA NUEVA COLECCIÓN</span></h2>
            </div>
        </div>


            <!-- Sneakers -->
            <div class="title-card">
                <h2>LISTA DE PRODUCTOS</h2>
            </div>

            <% products.forEach((product)=> { %>
                <div class="container">
                    <div class="product prod-desk">
                        <div class="product-card">

                            <h2 class="name">
                                <%= product.nombre %>
                            </h2>
                            <a href="/products/<%=product.id%>" class="popup-btn">Detalle</a>
                            <img class="product-img" src="/product_images/<%= product.imagen %>" alt="">                            
                        </div>
                    </div>
                </div>
                <% }) %>


                    <!-- FOOTER -->
                    <%-include("./partials/footer.ejs")%>
                        <!-- FIN FOOTER -->

    </body>

</html>