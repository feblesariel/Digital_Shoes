<!DOCTYPE html>
<html lang="en">
<%-include("./partials/head.ejs")%>
<body>
    <!-- Header -->
      <%-include("./partials/header.ejs")%>
    <!-- /Header -->

	<div class="container products-wrapper">
		<div class="row">
			<div class="col-12">
				<h2 class="products-title">Estás editando: xxxxxxxxxx </i></h2>
			</div>
		</div>
		<div class="col-12">
			<form action="/products/edit/xxxxxxxxx" method="POST" enctype="multipart/form-data">
				<div class="row product-detail">
					<div class="col-12 col-md-6">
						<label for="name" class="form-label">Nombre del producto:</label>
						<input value="xxxxxxxxxx" type="text" id="name" name="name" class="form-input">
					</div>
					<div class="col-12 col-md-6">
						<label for="price" class="form-label">Precio del producto:</label>
						<input value="xxxxxxxxxxxx"type="text" id="price" name="price"  class="form-input">
					</div>
					<div class="col-12 col-md-6">
						<label for="discount" class="form-label">Descuento:</label>
						<input value="xxxxxxxxxx"type="text" id="discount" name="discount"  class="form-input">
					</div>
					<div class="col-12 col-md-6">
						<label for="category" class="form-label">Categoría:</label>
						<select id="select" selectedIndex="xxxxxxxxxxxx" name="category"  class="form-input">
							<option value="">Elegí</option>
							<option value="in-sale">En oferta</option>
							<option value="visited" >Últimos agregados</option>
						</select>
					</div>
					<div class="col-12">
						<img src="/images/products/xxxxxxxxxxx" alt="">
					</div>
					
					<div class="col-12">
						
						<input type="file" name="product-image" id="product-image" >
				
				</div>
					<div class="col-12">
						<label for="description" class="form-label">Descipción:</label>
						<textarea name="description" id="description" class="form-input">xxxxxxxxxxxxxxxxx</textarea>
					</div>
					<div class="col-12">
						<button type="submit" class="buy-now-button">Guardar producto</button>
					</div>
				</div>
			</form>
		</div>

	</div>


	 <!-- FOOTER -->
    <%-include("./partials/footer.ejs")%>

    <!-- FIN FOOTER -->
</body>	
</html>
