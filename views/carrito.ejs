<!DOCTYPE html>
<html lang="en">

<%-include("./partials/head.ejs")%>

    <body>
        <%-include("./partials/header.ejs")%>
            <main>
                <br>
                <div class="contenedor-general">
                    <h2 class="titulares">Detalle de compra</h2>
                    <div class="contenedor-carrito"><br>
                        <div class="contenedor-item-carrito">
                            <% let suma = 0; let parcial = 0; if (locals.temp2) { temp2.forEach (item=> { %>
                                <% if (item.id !=0) { %>
                                    <div class="contenedor-detalle-carrito">
                                        <p>Producto: <%= item.nombre %>
                                        </p>
                                        <p>Precio: <%= item.precio %>
                                        </p>
                                    </div>
                                    <div class="contenedor-imagen-carrito">
                                        <p><img src="/images/<%=item.imagen%>" alt="" width="100px" height="75px"></p>
                                    </div>
                                    <% parcial = Number.parseInt(item.precio); suma += parcial }})} %>
                        </div>
                    </div>
                    <div class="contenedor-sub-total">
                        <div>
                            <p>Sub total: </p>
                        </div>
                        <div>
                            <p>TOTAL: <%=suma%> </p>
                        </div>
                    </div>
                </div>

            </main>
            <%-include("./partials/footer.ejs")%>
    </body>

</html>